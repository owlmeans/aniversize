{
  "name": "@owlmeans/aniversize",
  "version": "0.0.1",
  "description": "CLI tool for anniversary management and reminders",
  "type": "module",
  "bin": {
    "aniversize": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile dist/cli.js --target node && bun run ./scripts/postbuild.ts",
    "build:lib": "tsc --project tsconfig.build.json",
    "dev": "bun run ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "anniversary",
    "cli",
    "reminder",
    "dates"
  ],
  "author": "OwlMeans",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest-diff": "^24.3.0",
    "@types/node": "^22.0.0",
    "@types/through2": "^2.0.41",
    "bun-types": "^1.3.10",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.3.4",
    "globby": "^16.1.1",
    "jest-diff": "^30.3.0",
    "through2": "^4.0.2"
  }
}
